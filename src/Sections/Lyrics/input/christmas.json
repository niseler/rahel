{
  "nav": "Weihnachten",
  "intro": "Eine ode auf unser erstes Weihnachten zusammen",
  "verse": [
    [
      "Weihnachten das Fest der Liebe",
      "oh wie freue ich mich sehr.",
      "Hier zu sein sein bei meinen lieben",
      "Und aufs knutschen noch viel mehr."
    ],
    [
      "Bei drei ganz besondren Menschen ",
      "Die ich gern Familie nenne.",
      "Wo ich mich zu Hause fühle",
      "Bin so froh, dass ich euch kenne."
    ],
    [
      "Auch wird es Geschenke geben",
      "jeder wird heute reich bedacht.",
      "Bin gespannt ob meine Auswahl ",
      "allen eine Freude macht."
    ],
    [
      "Und dann sitzen wir bei Kerzen ",
      "Alle um den Gabentisch.",
      "Wärme ist in unsern Herzen",
      "Etwas anderes brauch ich nicht."
    ],
    [
      "Kulinarisch wird es lecker",
      "Sophia zaubert in der Küche.",
      "Auch für Juli wirds was geben",
      "Nur bitte keine Zusammenbrüche."
    ],
    [
      "Lieder werden auch gesungen",
      "Laut und schief und voller Lust.",
      "Jetzt hab ich glatt den Text vergessen",
      "Grad gab ich ihn noch gewusst."
    ],
    [
      "Und so sitzen wir beisammen",
      "Draußen schneits vielleicht sogar.",
      "Schmunzelnd schauen wir zurück",
      "Auf ein turbulentes Jahr."
    ],
    [
      "Für die großen gibt es Glühwein",
      "Für die kleinen kinderpunsch.",
      "Möge alles hier so bleiben",
      "Dieses ist mein einzger Wunsch."
    ]
  ]
}